        <MinFreq_Hz>17.0</MinFreq_Hz>
        <MaxFreq_Hz>28.0</MaxFreq_Hz>
        <Duration_s>21.0</Duration_s>
      </Parameters>
    </Detection>

    <Detection>
      <Start>2019-04-12T03:25:15</Start>
      <End>2019-04-12T03:25:36</End>
